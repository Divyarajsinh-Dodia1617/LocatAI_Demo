# ═══════════════════════════════════════════════════════════════
#  LocatAI Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Master Switch ─────────────────────────────────────────────
# Enable AI self-healing (required for LocatAI to activate)
# Use either SELF_HEAL=1 or AI_SELF_HEAL=true (both work)
SELF_HEAL=1
# AI_SELF_HEAL=true

# ── AI Provider ───────────────────────────────────────────────
# Which AI backend to use
# Options: openai | gpt | anthropic | claude | google | gemini | local | ollama
AI_PROVIDER=google

# ── API Key ───────────────────────────────────────────────────
# Required for cloud providers (OpenAI, Anthropic, Google)
# Not needed for local/ollama
AI_API_KEY=your-api-key-here

# ── Model Override (optional) ─────────────────────────────────
# Override the default model for your provider
# If not set, LocatAI uses these defaults:
#   OpenAI:    gpt-5-nano
#   Anthropic: claude-sonnet-4-20250514
#   Google:    gemini-2.5-flash
#   Local:     gemma3:4b
# AI_MODEL=gemini-2.5-flash-lite

# ── Ollama Host (local provider only) ─────────────────────────
# Custom Ollama server URL (e.g., running on another machine)
# Default: http://127.0.0.1:11434
# OLLAMA_HOST=http://192.168.1.100:11434

# ═══════════════════════════════════════════════════════════════
#  Fixture-Only Options (NOT configurable via env)
#  These are set programmatically in createLocatAIFixture({...})
#  or withLocatAI(page, {...}). Listed here for reference only.
# ═══════════════════════════════════════════════════════════════
#
#  maxCandidates  — Max DOM elements collected for AI (default: 80)
#  maxAiTries     — Max AI strategies to validate (default: 4)
#  timeout        — Locator timeout in ms (default: 5000)
#  cacheFile      — Path to healed locators cache (default: .self-heal/healed_locators.json)
#  reportFile     — Path to event log (default: .self-heal/heal_events.jsonl)
#  testName       — Current test name for cache entries (auto-set)
